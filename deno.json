{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vue-tsc --noEmit && deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "tauri": "deno run -A npm:@tauri-apps/cli"
  },
  "imports": {
    "vue": "npm:vue@^3.5.13",
    "monaco-editor": "npm:monaco-editor@^0.55.1",
    "@tauri-apps/api": "npm:@tauri-apps/api@^2",
    "@tauri-apps/plugin-dialog": "npm:@tauri-apps/plugin-dialog@^2",
    "@tauri-apps/plugin-opener": "npm:@tauri-apps/plugin-opener@^2",
    "@fortawesome/fontawesome-svg-core": "npm:@fortawesome/fontawesome-svg-core@^6",
    "@fortawesome/free-solid-svg-icons": "npm:@fortawesome/free-solid-svg-icons@^6",
    "@fortawesome/free-regular-svg-icons": "npm:@fortawesome/free-regular-svg-icons@^6",
    "@fortawesome/vue-fontawesome": "npm:@fortawesome/vue-fontawesome@^3",
    "@xterm/xterm": "npm:@xterm/xterm@^6.0.0",
    "@xterm/addon-fit": "npm:@xterm/addon-fit@^0.11.0",
    "sass": "npm:sass@^1.98.0",
    "typescript": "npm:typescript@~5.6.2",
    "vite": "npm:vite@^6.0.3",
    "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^5.2.1",
    "vue-tsc": "npm:vue-tsc@^2.1.10",
    "@tauri-apps/cli": "npm:@tauri-apps/cli@^2"
  }
}
